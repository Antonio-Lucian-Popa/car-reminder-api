{
  "name": "car-reminder-backend",
  "version": "1.0.0",
  "description": "Backend API for Car Reminder PWA / mobile app",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "docker:start": "sh docker-entrypoint.sh",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "seed": "tsx prisma/seed.ts",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "car",
    "reminder",
    "express",
    "prisma",
    "postgresql",
    "jwt",
    "push"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@prisma/client": "6.19.3",
    "@types/multer": "^2.1.0",
    "bcryptjs": "3.0.3",
    "compression": "1.8.1",
    "cookie-parser": "1.4.7",
    "cors": "2.8.6",
    "date-fns": "4.2.1",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "express-rate-limit": "8.5.2",
    "helmet": "8.1.0",
    "jsonwebtoken": "9.0.3",
    "morgan": "1.10.1",
    "multer": "^2.1.1",
    "node-cron": "4.2.1",
    "nodemailer": "^8.0.11",
    "pdfkit": "^0.19.1",
    "prisma": "6.19.3",
    "sharp": "^0.35.1",
    "uuid": "14.0.0",
    "web-push": "3.6.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/compression": "1.8.1",
    "@types/cookie-parser": "1.4.10",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/jsonwebtoken": "9.0.10",
    "@types/morgan": "1.9.10",
    "@types/node": "^25.9.1",
    "@types/nodemailer": "^8.0.1",
    "@types/pdfkit": "^0.17.6",
    "@types/sharp": "^0.31.1",
    "@types/web-push": "3.6.4",
    "@vitest/coverage-v8": "^4.1.8",
    "tsx": "4.22.3",
    "typescript": "5.9.3",
    "vitest": "^4.1.8"
  }
}
