generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  ACCOUNTANT
  EMPLOYEE
}

enum ReminderCategory {
  ITP
  RCA
  CASCO
  ROVINIETA
  REVIZIE
  SCHIMB_ULEI
  SCHIMB_ANVELOPE
  TAXE
  CUSTOM
}

enum ReminderRepeat {
  NONE
  MONTHLY
  YEARLY
  CUSTOM
}

enum ReminderStatus {
  ACTIVE
  DUE_SOON
  EXPIRED
  RENEWED
}

enum DeviceType {
  WEB_PUSH
  EXPO_PUSH
}

enum DevicePlatform {
  WEB
  IOS
  ANDROID
}

enum CostCategory {
  FUEL
  REPAIR
  SERVICE
  INSURANCE
  ROAD_TAX
  ROVINIETA
  ITP
  PARKING
  WASHING
  PARTS
  OTHER
}

enum FuelKind {
  benzina
  motorina
  gpl
  electric
  hybrid
}

enum DocumentType {
  RCA
  CASCO
  ITP
  ROVINIETA
  INVOICE
  FUEL_RECEIPT
  SERVICE_RECEIPT
  OTHER
}

enum TripStatus {
  ACTIVE
  CLOSED
  SUBMITTED
  APPROVED
  REJECTED
}

enum ExpenseCategory {
  COMBUSTIBIL
  MASA
  CAZARE
  TRANSPORT
  DIURNA
  ALTELE
}

model Company {
  id              String   @id @default(uuid())
  name            String
  cif             String?  @unique
  accountantEmail String?
  settings        Json     @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users    User[]
  cars     Car[]
  trips    Trip[]
  expenses Expense[]
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  firstName    String?
  lastName     String?
  companyId    String
  role         UserRole @default(EMPLOYEE)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company       Company              @relation(fields: [companyId], references: [id], onDelete: Restrict)
  refreshTokens RefreshToken[]
  devices       NotificationDevice[]

  @@index([companyId])
}

model RefreshToken {
  id         String    @id @default(uuid())
  tokenHash  String    @unique
  userId     String
  expiresAt  DateTime
  revokedAt  DateTime?
  replacedBy String?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Car {
  id             String   @id @default(uuid())
  companyId      String
  assignedUserId String?
  make           String
  model          String
  year           Int?
  plateNumber    String
  vin            String?
  mileage        Int?
  imageUrl       String?
  color          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  reminders Reminder[]
  costs     Cost[]
  fuelLogs  FuelLog[]
  documents Document[]
  trips     Trip[]

  @@unique([companyId, plateNumber])
  @@index([companyId])
}

model Cost {
  id              String       @id @default(uuid())
  carId           String
  category        CostCategory
  amount          Decimal      @db.Decimal(10, 2)
  currency        String       @default("RON")
  date            DateTime
  mileage         Int?
  vendor          String?
  notes           String?
  receiptImageUrl String?
  linkedExpenseId String?
  createdAt       DateTime     @default(now())

  car Car @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@index([carId, date])
}

model FuelLog {
  id              String   @id @default(uuid())
  carId           String
  date            DateTime
  station         String?
  fuelType        FuelKind
  liters          Decimal  @db.Decimal(8, 2)
  pricePerLiter   Decimal  @db.Decimal(8, 3)
  total           Decimal  @db.Decimal(10, 2)
  mileage         Int?
  fullTank        Boolean  @default(true)
  receiptImageUrl String?
  createdAt       DateTime @default(now())

  car Car @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@index([carId, date])
}

model Document {
  id               String       @id @default(uuid())
  carId            String
  type             DocumentType
  title            String
  imageUrl         String
  linkedCostId     String?
  linkedReminderId String?
  createdAt        DateTime     @default(now())

  car Car @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@index([carId])
}

model Reminder {
  id               String           @id @default(uuid())
  userId           String
  carId            String
  title            String
  category         ReminderCategory @default(CUSTOM)
  expiresAt        DateTime
  notifyBeforeDays Int              @default(7)
  repeat           ReminderRepeat   @default(NONE)
  customRepeatDays Int?
  notes            String?
  status           ReminderStatus   @default(ACTIVE)
  lastNotifiedAt   DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  car Car @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([carId])
  @@index([expiresAt])
}

model NotificationDevice {
  id            String         @id @default(uuid())
  userId        String
  type          DeviceType
  platform      DevicePlatform
  endpoint      String?
  p256dh        String?
  auth          String?
  expoPushToken String?
  userAgent     String?
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@unique([userId, endpoint])
  @@unique([userId, expoPushToken])
}

model Trip {
  id          String     @id @default(uuid())
  companyId   String
  userId      String
  destination String
  purpose     String?
  startDate   DateTime
  endDate     DateTime?
  budget      Decimal?   @db.Decimal(10, 2)
  carId       String?
  kmStart     Int?
  kmEnd       Int?
  status      TripStatus @default(ACTIVE)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  company  Company   @relation(fields: [companyId], references: [id])
  car      Car?      @relation(fields: [carId], references: [id])
  expenses Expense[]

  @@index([companyId, userId])
  @@index([companyId, status])
}

model Expense {
  id          String          @id @default(uuid())
  companyId   String
  userId      String
  tripId      String?
  category    ExpenseCategory @default(ALTELE)
  amount      Decimal         @db.Decimal(10, 2)
  currency    String          @default("RON")
  date        DateTime
  merchant    String?
  merchantCif String?
  notes       String?
  imageUrl    String?
  ocrRaw      Json?
  verified    Boolean         @default(false)
  createdAt   DateTime        @default(now())

  company Company @relation(fields: [companyId], references: [id])
  trip    Trip?   @relation(fields: [tripId], references: [id], onDelete: SetNull)

  @@index([companyId, date])
  @@index([tripId])
}
